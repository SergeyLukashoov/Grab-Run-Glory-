org, repo = (ENV["GITHUB_REPOSITORY"] || "").split("/")

def normalize_repo_slug(value)
  return "" if value.to_s.strip.empty?

  slug = value.strip
  slug = slug.sub(%r{\Agit@github\.com:}, "")
  slug = slug.sub(%r{\Ahttps?://github\.com/}, "")
  slug = slug.sub(%r{\.git\z}, "")
  slug
end

def github_https_repo_url(value, fallback_org = nil, fallback_repo = nil)
  slug = normalize_repo_slug(value)
  if slug.empty? && !fallback_org.to_s.strip.empty? && !fallback_repo.to_s.strip.empty?
    slug = "#{fallback_org}/#{fallback_repo}"
  end
  return "" if slug.empty?

  "https://github.com/#{slug}.git"
end

def bump_patch_version(version)
  parts = version.to_s.split(".").map(&:to_i)
  parts << 0 while parts.length < 3
  parts[2] += 1
  parts.join(".")
end

match_repo_source = ENV["MATCH_REPOSITORY"] || ENV["MATCH_GIT_URL"]
match_org, match_repo = normalize_repo_slug(match_repo_source).split("/")

platform :ios do
  before_all do
    ENV["FASTLANE_XCODEBUILD_SETTINGS_TIMEOUT"] ||= "120"
  end

  lane :init_ci do
    github_action(
      api_token: ENV["GH_PAT"],
      org: org,
      repo: repo,
      match_org: match_org,
      match_repo: match_repo,
      writable_deploy_key: true
    )
  end

  desc "Sync codesigning certificates"
  lane :sync_certificates do
    key_id = ENV["APPSTORE_KEY_ID"] || ENV["ASC_KEY_ID"]
    issuer_id = ENV["APPSTORE_ISSUER_ID"] || ENV["ASC_ISSUER_ID"]
    key_content = ENV["APPSTORE_P8"] || ENV["ASC_KEY"]

    app_store_connect_api_key(
      key_id: key_id,
      issuer_id: issuer_id,
      key_content: key_content
    )

    main_app_bundle_id = ENV["IOS_BUNDLE_ID"] || ENV["BUNDLE_IDENTIFIER"]

    resolved_match_git_url = github_https_repo_url(
      ENV["MATCH_GIT_URL"] || ENV["MATCH_REPOSITORY"],
      match_org,
      match_repo
    )
    UI.user_error!("MATCH_GIT_URL or MATCH_REPOSITORY must point to a GitHub repo") if resolved_match_git_url.empty?

    match(
      type: "appstore",
      storage_mode: "git",
      git_url: resolved_match_git_url,
      app_identifier: [main_app_bundle_id],
      readonly: false
    )
  end

  desc "Deliver a new Release build to the App Store"
  lane :release do
    build
    deliver
    upload_to_app_store(
      submit_for_review: false,
      automatic_release: false,
      force: true,
      skip_screenshots: true,
      run_precheck_before_submit: false
    )
  end

  desc "Deliver a new Beta build to Apple TestFlight"
  lane :beta do
    update_info_plist(
      xcodeproj: "#{ENV['IOS_BUILD_PATH']}/iOS/Unity-iPhone.xcodeproj",
      plist_path: 'Info.plist',
      block: proc do |plist|
        plist['ITSAppUsesNonExemptEncryption'] = false
      end
    )

    update_info_plist(
      xcodeproj: "#{ENV['IOS_BUILD_PATH']}/iOS/Unity-iPhone.xcodeproj",
      plist_path: 'Info.plist',
      block: proc do |plist|
        plist['MinimumOSVersion'] = '16.0'
      end
    )

    build
    upload_to_testflight(skip_waiting_for_build_processing: true)
  end

  desc "Full CI lane for TestFlight upload"
  lane :full_build_upload_testflight do
    beta
  end

  desc "List Provisioning Profiles"
  lane :list_profiles do
    sh "security find-identity -v -p codesigning"
  end

  desc "Create .ipa"
  lane :build do
    ios_bundle_id = ENV["IOS_BUNDLE_ID"] || ENV["BUNDLE_IDENTIFIER"]
    xcode_project_path = "#{ENV['IOS_BUILD_PATH']}/iOS/Unity-iPhone.xcodeproj"

    setup_ci
    sync_certificates
    list_profiles

    update_code_signing_settings(
      use_automatic_signing: true,
      path: xcode_project_path
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      team_id: ENV["sigh_#{ios_bundle_id}_appstore_team-id"],
      code_sign_identity: 'iPhone Distribution',
      targets: 'Unity-iPhone',
      path: xcode_project_path,
      profile_name: ENV["sigh_#{ios_bundle_id}_appstore_profile-name"],
      profile_uuid: ENV["sigh_#{ios_bundle_id}_appstore"]
    )

    requested_version = (ENV['MAJOR_VERSION'] || ENV['APP_VERSION'] || "").strip
    requested_version = "1.0" if requested_version.empty?
    version_number = requested_version
    begin
      live_version = get_app_store_version_number(
        app_identifier: ios_bundle_id,
        live: true,
        platform: "ios"
      )
      if Gem::Version.correct?(live_version) && Gem::Version.correct?(version_number) && Gem::Version.new(version_number) <= Gem::Version.new(live_version)
        version_number = bump_patch_version(live_version)
        UI.important("Requested version #{requested_version} is not higher than live #{live_version}. Using #{version_number}.")
      end
    rescue => e
      UI.important("Could not determine live App Store version: #{e.message}")
    end

    increment_version_number(version_number: version_number, xcodeproj: xcode_project_path)

    latest_build_number = 0
    begin
      latest_build_number = latest_testflight_build_number(
        version: version_number,
        app_identifier: ios_bundle_id
      )
    rescue => e
      UI.important("Could not read latest TestFlight build number for #{version_number}: #{e.message}")
      latest_build_number = 0
    end
    increment_build_number(
      build_number: latest_build_number.to_i + 1,
      xcodeproj: xcode_project_path
    )

    build_app(
      project: xcode_project_path,
      scheme: 'Unity-iPhone',
      xcargs: '-allowProvisioningUpdates IPHONEOS_DEPLOYMENT_TARGET=16.0 DEAD_CODE_STRIPPING=YES STRIP_INSTALLED_PRODUCT=YES',
      export_options: {
        method: 'app-store',
        uploadBitcode: false,
        compileBitcode: false,
      }
    )
  end
end
